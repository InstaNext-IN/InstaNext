{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Listing": {
      "title": "Listing",
      "description": "Product listing for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" }, "address": { "type": "string" } } },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "title", "price", "category"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users about a listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "listingId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "listingId"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "listingId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "receiverId", "listingId", "text"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Product listings"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    }
  }
}
